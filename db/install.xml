<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="report/adeptus_insights/db" VERSION="2026012701" COMMENT="Adeptus Insights DB schema with Stripe integration">
    <TABLES>

        <!-- 1. Materialized Base Table -->
        <TABLE NAME="report_adeptus_insights_analytics" COMMENT="Nightly flattened snapshot of user-course interactions">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="logins" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="assignments_submitted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="forum_posts" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="resource_clicks" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="last_login" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="average_grade" TYPE="number" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 2. Report Result Cache -->
        <TABLE NAME="report_adeptus_insights_cache" COMMENT="Cached report results by user/session for fast reloads">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="reportid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="jsondata" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="hashkey" TYPE="char" LENGTH="64" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="uniqcache" TYPE="unique" FIELDS="userid,hashkey"/>
            </KEYS>
        </TABLE>

        <!-- 3. Report Configurations -->
        <TABLE NAME="report_adeptus_insights_config" COMMENT="User-created report metadata (fields, filters, questions)">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="name" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="question" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="fields" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="filters" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="visualization" TYPE="char" LENGTH="50" NOTNULL="false"/>
                <FIELD NAME="shared" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 4. Predefined and Custom Reports Table for Report Wizard -->
        <!-- NOTE: This table is currently unused in code. Report definitions are fetched from the
             backend API. Retained for planned offline/local report definitions feature. -->
        <TABLE NAME="report_adeptus_insights_reports" COMMENT="Predefined and custom reports for the wizard - reserved for future local report definitions">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="category" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="sqlquery" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="parameters" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="charttype" TYPE="char" LENGTH="50" NOTNULL="false"/>
                <FIELD NAME="isactive" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
                <FIELD NAME="min_moodle_version" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="max_moodle_version" TYPE="char" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 5. User Report History Table for Report Wizard -->
        <TABLE NAME="report_adeptus_insights_history" COMMENT="User report generation history for wizard">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="reportid" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="parameters" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="generatedat" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="resultpath" TYPE="char" LENGTH="255" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 6. User Bookmarks Table for Report Wizard -->
        <TABLE NAME="report_adeptus_insights_bookmarks" COMMENT="User report bookmarks for wizard">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="reportid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="createdat" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 7. Installation Settings Table -->
        <TABLE NAME="report_adeptus_insights_settings" COMMENT="Plugin installation settings and API configuration">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="api_key" TYPE="char" LENGTH="64" NOTNULL="true"/>
                <FIELD NAME="api_url" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="installation_id" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="is_registered" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="registration_date" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="last_sync" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="settings" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="uniqapikey" TYPE="unique" FIELDS="api_key"/>
            </KEYS>
        </TABLE>

        <!-- 8. Enhanced Subscription Status Table with Stripe Integration -->
        <TABLE NAME="report_adeptus_insights_subscription" COMMENT="Local subscription status tracking with Stripe integration">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="stripe_customer_id" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="stripe_subscription_id" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="plan_name" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="plan_id" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="50" NOTNULL="true"/>
                <FIELD NAME="current_period_start" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="current_period_end" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="ai_credits_remaining" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="ai_credits_pro_remaining" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="ai_credits_basic_remaining" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="exports_remaining" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="billing_email" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="last_updated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="stripe_customer" TYPE="unique" FIELDS="stripe_customer_id"/>
            </KEYS>
        </TABLE>

        <!-- 9. Stripe Webhook Events Table -->
        <TABLE NAME="report_adeptus_insights_webhooks" COMMENT="Stripe webhook event tracking">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="stripe_event_id" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="event_type" TYPE="char" LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="stripe_customer_id" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="stripe_subscription_id" TYPE="char" LENGTH="100" NOTNULL="false"/>
                <FIELD NAME="event_data" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="processed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="stripe_event" TYPE="unique" FIELDS="stripe_event_id"/>
            </KEYS>
        </TABLE>

        <!-- 10. Usage Tracking Table -->
        <TABLE NAME="report_adeptus_insights_usage" COMMENT="Track AI credits and export usage">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="usage_type" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="credits_used" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1"/>
                <FIELD NAME="model_type" TYPE="char" LENGTH="20" NOTNULL="false"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="user_usage" TYPE="unique" FIELDS="userid,usage_type"/>
            </KEYS>
        </TABLE>

        <!-- 11. Export Tracking for Free Plan Users -->
        <TABLE NAME="report_adeptus_insights_exports" COMMENT="Track exports for free plan users">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="reportname" TYPE="text" NOTNULL="true"/>
                <FIELD NAME="format" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="exportedat" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="exportedat_idx" UNIQUE="false" FIELDS="exportedat"/>
            </INDEXES>
        </TABLE>

        <!-- 12. Generated Reports Table -->
        <TABLE NAME="report_adeptus_insights_generated" COMMENT="Stores generated report metadata for the Generated Reports section">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="reportid" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="parameters" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="generatedat" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="resultpath" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="counted_for_usage" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="generatedat_idx" UNIQUE="false" FIELDS="generatedat"/>
            </INDEXES>
        </TABLE>

        <!-- 13. Stripe Configuration Table -->
        <TABLE NAME="report_adeptus_insights_stripe" COMMENT="Stripe payment gateway configuration">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="publishable_key" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="secret_key" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="webhook_secret" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="is_test_mode" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
                <FIELD NAME="currency" TYPE="char" LENGTH="3" NOTNULL="true" DEFAULT="GBP"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

        <TABLE NAME="report_adeptus_insights_plans" COMMENT="Subscription plan definitions for Adeptus Insights">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="stripe_product_id" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="stripe_price_id" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="ai_credits" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="ai_credits_pro" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="ai_credits_basic" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="exports" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="ix_stripe_price_id" UNIQUE="true" FIELDS="stripe_price_id"/>
                <INDEX NAME="ix_stripe_product_id" UNIQUE="false" FIELDS="stripe_product_id"/>
            </INDEXES>
        </TABLE>

        <!-- 15. Scheduled Reports Configuration -->
        <TABLE NAME="report_adeptus_insights_schedules" COMMENT="Scheduled report configuration — one row per schedule">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="reportid" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="label" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="frequency" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="weekly"/>
                <FIELD NAME="run_hour" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="7"/>
                <FIELD NAME="run_dayofweek" TYPE="int" LENGTH="1" NOTNULL="false"/>
                <FIELD NAME="run_dayofmonth" TYPE="int" LENGTH="2" NOTNULL="false"/>
                <FIELD NAME="export_format" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="csv"/>
                <FIELD NAME="report_params" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="email_subject" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="email_body" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="active" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
                <FIELD NAME="last_run" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="next_run" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="failure_count" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="created_by" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_created_by" TYPE="foreign" FIELDS="created_by" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="idx_next_run_active" UNIQUE="false" FIELDS="next_run,active"/>
                <INDEX NAME="idx_reportid" UNIQUE="false" FIELDS="reportid"/>
            </INDEXES>
        </TABLE>

        <!-- 16. Schedule Recipients -->
        <TABLE NAME="report_adeptus_insights_sched_recip" COMMENT="Recipients per scheduled report">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="scheduleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="recipient_type" TYPE="char" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="email" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="roleid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_scheduleid" TYPE="foreign" FIELDS="scheduleid" REFTABLE="report_adeptus_insights_schedules" REFFIELDS="id"/>
                <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="fk_roleid" TYPE="foreign" FIELDS="roleid" REFTABLE="role" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- 17. Schedule Execution Log -->
        <TABLE NAME="report_adeptus_insights_sched_log" COMMENT="Execution log for scheduled report runs">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="scheduleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="recipients_sent" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="recipients_failed" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="export_format" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="attachment_size" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="row_count" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="error_message" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_scheduleid" TYPE="foreign" FIELDS="scheduleid" REFTABLE="report_adeptus_insights_schedules" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="idx_scheduleid_timecreated" UNIQUE="false" FIELDS="scheduleid,timecreated"/>
                <INDEX NAME="idx_status_timecreated" UNIQUE="false" FIELDS="status,timecreated"/>
            </INDEXES>
        </TABLE>

        <!-- 18. Alert Configuration -->
        <TABLE NAME="report_adeptus_alert_config" COMMENT="Alert configuration settings for at-risk learner digests">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="alert_type" TYPE="char" LENGTH="50" NOTNULL="true"/>
                <FIELD NAME="threshold_value" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
                <FIELD NAME="created_by" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="idx_alert_type" UNIQUE="true" FIELDS="alert_type"/>
            </INDEXES>
        </TABLE>

        <!-- 19. Alert Digest Log -->
        <TABLE NAME="report_adeptus_alert_log" COMMENT="Tracks sent alert digests to prevent duplicates">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="period_key" TYPE="char" LENGTH="20" NOTNULL="true"/>
                <FIELD NAME="recipients_sent" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="learners_found" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="idx_period_key" UNIQUE="true" FIELDS="period_key"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>
